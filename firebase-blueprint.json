{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores basic user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth unique ID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's full name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the system" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "SavedKnowledge": {
      "title": "Saved Clinical Knowledge",
      "description": "Stores clinical knowledge bookmarked by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who saved this knowledge" },
        "type": { "type": "string", "enum": ["drug", "protocol", "lab", "encyclopedia"], "description": "The category of knowledge" },
        "title": { "type": "string", "description": "The name of the drug, condition, or test" },
        "data": { "type": "object", "description": "The full AI-generated clinical data object" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the knowledge was bookmarked" }
      },
      "required": ["userId", "type", "title", "data", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/saved_knowledge/{knowledgeId}": {
      "schema": "SavedKnowledge",
      "description": "Collection of bookmarked clinical knowledge."
    }
  }
}
