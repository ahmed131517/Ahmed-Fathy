rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (optional)
    //   - photoURL: string (optional, uri format)
    //   - role: string (required, 'admin' or 'user')
    //   - createdAt: timestamp (required)
    //
    // Collection: saved_knowledge
    // Document ID: {knowledgeId}
    // Fields:
    //   - userId: string (required)
    //   - type: string (required, 'drug', 'protocol', 'lab', 'encyclopedia')
    //   - title: string (required)
    //   - data: map (required, the AI-generated content)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ahmedfathyalihussien@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    function isValidSavedKnowledge(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'data', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['drug', 'protocol', 'lab', 'encyclopedia'] &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.data is map &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin()) && 
                    request.resource.data.role == resource.data.role; // Prevent self-role escalation
    }

    match /saved_knowledge/{knowledgeId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSavedKnowledge(request.resource.data);
      allow update: if isAuthenticated() && isValidSavedKnowledge(request.resource.data) && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
